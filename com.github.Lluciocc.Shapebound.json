{
    "id" : "com.github.Lluciocc.Shapebound",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "shapebound",
    "finish-args" : [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "shapebound",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
		{
		    "type": "git",
		    "url": "https://github.com/Lluciocc/Shapebound.git",
		    "commit": "3617c6ef3e405fb9e4fbeeb257d428d8895dbd8e"
		}
            ]
        }
    ]
}
